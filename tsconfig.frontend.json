{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "public",
    "rootDir": "public",
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "isolatedModules": false
  },
  "include": ["public/app.ts"],
  "exclude": ["node_modules", "dist"]
}